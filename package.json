{
  "name": "ringi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "demo": "tsx src/demo/sales-agent-demo.ts",
    "demo:record": "PACE=1 tsx src/demo/sales-agent-demo.ts",
    "mcp": "tsx src/mcp/gateway.ts",
    "mcp:smoke": "tsx src/mcp/smoke.ts",
    "ingest": "tsx src/ingest/notion-to-charter.ts",
    "db:up": "docker compose up -d",
    "db:migrate": "docker compose exec -T postgres psql -U ringi -d ringi -f /dev/stdin < db/schema.sql",
    "db:down": "docker compose down",
    "build:worker": "opennextjs-cloudflare build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "pg-cloudflare": "^1.4.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "tsx": "^4.23.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
